{
  "name": "@metalsmith/htmlmin",
  "private": true,
  "version": "0.0.0",
  "description": "A metalsmith plugin to minify html using htmlnano",
  "keywords": [
    "html",
    "minify",
    "html-minifier",
    "metalsmith-plugin",
    "metalsmith",
    "static-site"
  ],
  "source": "src/index.js",
  "main": "lib/index.cjs",
  "module": "lib/index.js",
  "type": "module",
  "exports": {
    "import": "./lib/index.js",
    "require": "./lib/index.cjs"
  },
  "types": "lib/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metalsmith/htmlmin.git"
  },
  "files": [
    "lib",
    "src"
  ],
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "author": "Kevin Van Lierde (https://webketje.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/metalsmith/htmlmin/issues"
  },
  "homepage": "https://github.com/metalsmith/htmlmin#readme",
  "devDependencies": {
    "assert-dir-equal": "^1.1.0",
    "auto-changelog": "^2.5.0",
    "c8": "^10.1.3",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.3.0",
    "metalsmith": "^2.7.0",
    "microbundle": "^0.15.1",
    "mocha": "^11.3.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4"
  },
  "peerDependencies": {
    "metalsmith": "^2.7.0"
  },
  "scripts": {
    "changelog": "auto-changelog -u --commit-limit false --ignore-commit-pattern '^((dev|chore|ci):|Release)'",
    "coverage": "npm test && c8 report --reporter=text-lcov > coverage.info",
    "format": "prettier --write \"**/*.{yml,md,js,json}\"",
    "format:check": "prettier --list-different \"**/*.{yml,md,js,json}\"",
    "lint": "eslint --fix .",
    "lint:check": "eslint --fix-dry-run .",
    "release": "npm run build && release-it .",
    "build": "microbundle --target node -f cjs,esm --strict --generateTypes=false",
    "prepack": "npm run build",
    "test": "c8 mocha"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
